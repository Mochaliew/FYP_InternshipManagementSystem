@model LoginViewModel
@{
    ViewData["Title"] = "Student Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-box {
        background: #fff;
        width: 420px;
        max-width: 90%;
        border-radius: 14px;
        padding: 25px;
        box-shadow: 0 20px 45px rgba(0,0,0,.25);
    }

        .modal-box h4 {
            margin-bottom: 18px;
            font-weight: 700;
        }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 18px;
    }
</style>

<div class="auth-page student-auth-bg">
    <div class="auth-breadcrumb">Student Login</div>

    <div class="auth-outer auth-outer-right">
        <a href="/" class="back-link">&#8592; Back to Home</a>

        <div class="auth-card">
            <h2>Student Login</h2>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert-success">@TempData["Success"]</div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert-error">@TempData["Error"]</div>
                }

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" class="form-input" placeholder="Enter your Email ( XXX@edu.my )" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-input" placeholder="Enter your Password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-row-between">
                    <label class="checkbox-label">
                        <input asp-for="RememberMe" type="checkbox" /> Remember me
                    </label>

                    <a href="javascript:void(0)" onclick="openModal('forgotPwdModal')">
                        Forgot Password ?
                    </a>
                </div>

                <button type="submit" class="btn-dark btn-full mt-2">Login</button>
            </form>

            <div class="auth-footer">
                Doesn't have an Account ? <a href="/StudentAuth/Register">Register Here</a>
            </div>
        </div>
    </div>
</div>

<div id="forgotPwdModal" class="modal-overlay" onclick="backdropClose(event,'forgotPwdModal')">
    <div class="modal-box">
        <h4>Forgot Password</h4>

        <form asp-controller="StudentAuth"
              asp-action="ForgotPassword"
              method="post"
              autocomplete="off">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Registered Email</label>
                <input name="Email"
                       type="email"
                       class="form-input"
                       autocomplete="off" />
            </div>

            <div class="form-group">
                <label>New Password</label>
                <input name="NewPassword"
                       type="password"
                       class="form-input"
                       autocomplete="new-password" />
            </div>

            <div class="form-group">
                <label>Confirm New Password</label>
                <input name="ConfirmPassword"
                       type="password"
                       class="form-input"
                       autocomplete="new-password" />
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-muted" onclick="closeModal('forgotPwdModal')">Cancel</button>
                <button type="submit" class="btn-dark">Reset Password</button>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.PopupMessage != null)
{
    <script>
        window.onload = function () {
            alert('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(ViewBag.PopupMessage.ToString()))');
        };
    </script>
}

<script>
    function openModal(id) {

    var modal = document.getElementById(id);

    modal.style.display = 'flex';

    if (id === 'forgotPwdModal') {

        modal.querySelector('input[name="Email"]').value = "";
        modal.querySelector('input[name="NewPassword"]').value = "";
        modal.querySelector('input[name="ConfirmPassword"]').value = "";

        modal.querySelector('input[name="Email"]').focus();
    }
}

    function closeModal(id) {
        document.getElementById(id).style.display = 'none';
    }

    function backdropClose(event, id) {
        if (event.target === document.getElementById(id)) {
            closeModal(id);
        }
    }
</script>
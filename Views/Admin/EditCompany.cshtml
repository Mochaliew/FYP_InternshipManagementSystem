@model AdminEditCompanyViewModel
@{
    ViewData["Title"] = "Edit Company";
}

@await Html.PartialAsync("_AdminNav")

<style>
    .edit-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .edit-form-grid .full { grid-column: 1 / -1; }
    .form-action-row { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; }

    @@media (max-width: 800px) {
        .edit-form-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="admin-page-header">
    <div>
        <div class="admin-page-title">Edit Company</div>
        <div class="admin-page-sub">Update company profile details and account status</div>
    </div>
</div>

<div class="admin-table-card" style="max-width:900px">
    <form asp-action="EditCompany" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CompanyId" />

        <div class="edit-form-grid">
            <div class="form-group">
                <label>Company Name</label>
                <input asp-for="Name" class="form-input" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-input" readonly />
            </div>

            <div class="form-group">
                <label>Contact Number</label>
                <input asp-for="CompanyContactNum" class="form-input" />
            </div>

            <div class="form-group">
                <label>Industry Type</label>
                <input asp-for="IndustryType" class="form-input" />
            </div>

            <div class="form-group full">
                <label>Location</label>
                <input asp-for="CompanyLocation" class="form-input" />
            </div>

            <div class="form-group full">
                <label>Description</label>
                <textarea asp-for="Description" class="form-input" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label>Status</label>
                <select asp-for="Status" class="admin-select">
                    <option value="Active">Active</option>
                    <option value="Deactivated">Deactivated</option>
                </select>
            </div>
        </div>

        <div class="form-action-row">
            <a href="/Admin/ManageAccount" class="btn-muted">Cancel</a>
            <button type="submit" class="btn-dark">Save Changes</button>
        </div>
    </form>
</div>

@await Html.PartialAsync("_AdminNavClose")

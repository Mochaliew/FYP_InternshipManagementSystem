@model List<FYP_InternshipManagementSystem.Models.Application>
@{
    ViewData["Title"] = "Monitoring & Reporting";
}

@await Html.PartialAsync("_AdminNav")

<style>
    .admin-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 22px;
    }

    .admin-page-title {
        font-size: 28px;
        font-weight: 800;
        color: #1f2937;
        margin: 0;
    }

    .admin-page-desc {
        color: #6b7280;
        margin: 6px 0 0;
    }

    .quick-action-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .quick-action-btn {
        padding: 10px 14px;
        border-radius: 10px;
        background: #1f2937;
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
    }

    .quick-action-btn:hover { color: #fff; }

    .monitor-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 22px;
    }

    .monitor-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .monitor-label {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 8px;
    }

    .monitor-value {
        font-size: 28px;
        font-weight: 800;
        color: #111827;
    }

    .monitor-wide-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
        margin-bottom: 18px;
    }

    .section-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        margin-bottom: 14px;
    }

    .section-title {
        font-size: 19px;
        font-weight: 800;
        color: #1f2937;
        margin: 0;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 13px;
        margin-top: 4px;
    }

    .status-badge {
        display: inline-block;
        min-width: 82px;
        text-align: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        background: #eef2ff;
        color: #3730a3;
    }

    .status-badge.approved { background: #dcfce7; color: #166534; }
    .status-badge.rejected { background: #fee2e2; color: #991b1b; }
    .status-badge.pending { background: #fef3c7; color: #92400e; }

    .nice-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .nice-table th {
        background: #f8fafc;
        color: #374151;
        font-size: 13px;
        text-align: left;
        padding: 13px 14px;
    }

    .nice-table td {
        padding: 13px 14px;
        border-top: 1px solid #e5e7eb;
        color: #374151;
        vertical-align: middle;
    }

    .nice-table tr:nth-child(even) td { background: #fcfcfd; }

    @@media (max-width: 1000px) {
        .monitor-grid { grid-template-columns: repeat(2, 1fr); }
        .admin-page-header { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Monitoring & Reporting</h2>
        <p class="admin-page-desc">Track application activities, internship performance, and generate reports from one admin page.</p>
    </div>
    <div class="quick-action-row">
        <a asp-controller="Admin" asp-action="Reports" class="quick-action-btn">Generate Report</a>
        <a asp-controller="Admin" asp-action="ReportPreview" target="_blank" class="quick-action-btn">Preview Report</a>
    </div>
</div>

<div class="monitor-grid">
    <div class="monitor-card"><div class="monitor-label">Total Applications</div><div class="monitor-value">@ViewBag.TotalApplications</div></div>
    <div class="monitor-card"><div class="monitor-label">Pending Applications</div><div class="monitor-value">@ViewBag.PendingApplications</div></div>
    <div class="monitor-card"><div class="monitor-label">Approved Applications</div><div class="monitor-value">@ViewBag.ApprovedApplications</div></div>
    <div class="monitor-card"><div class="monitor-label">Rejected Applications</div><div class="monitor-value">@ViewBag.RejectedApplications</div></div>
    <div class="monitor-card"><div class="monitor-label">Active Internships</div><div class="monitor-value">@ViewBag.ActiveInternships</div></div>
    <div class="monitor-card"><div class="monitor-label">Total Students</div><div class="monitor-value">@ViewBag.TotalStudents</div></div>
    <div class="monitor-card"><div class="monitor-label">Total Companies</div><div class="monitor-value">@ViewBag.TotalCompanies</div></div>
</div>

<div class="monitor-wide-card">
    <div class="section-row">
        <div>
            <h3 class="section-title">Latest Applications</h3>
            <div class="section-subtitle">Newest student internship applications submitted in the system.</div>
        </div>
    </div>

    <table class="nice-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Company</th>
                <th>Internship</th>
                <th>Status</th>
                <th>Applied Date</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model.Take(15))
                {
                    var statusClass = item.Status?.ToLower() ?? "pending";
                    <tr>
                        <td><strong>@item.Student.User.Name</strong></td>
                        <td>@item.Internship.Company.User.Name</td>
                        <td>@item.Internship.Title</td>
                        <td><span class="status-badge @statusClass">@item.Status</span></td>
                        <td>@item.AppliedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No applications found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_AdminNavClose")

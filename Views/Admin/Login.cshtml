@model LoginViewModel
@{
    ViewData["Title"] = "Administrator Login";
}
<div class="auth-page admin-auth-bg">
    <div class="auth-breadcrumb">Administrator Login</div>
    <div class="auth-outer auth-outer-right">
        <a href="/" class="back-link">&#8592; Back to Home</a>
        <div class="auth-card">
            <h2>Administrator Login</h2>
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" class="form-input" placeholder="Enter your Email" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-input" placeholder="Enter your Password" />
                </div>
                <div class="form-row-between">
                    <label class="checkbox-label"><input asp-for="RememberMe" type="checkbox" /> Remember me</label>
                    <a href="#" class="link-muted">Forgot Password ?</a>
                </div>
                <button type="submit" class="btn-dark btn-full mt-2">Login</button>
            </form>
        </div>
    </div>
</div>

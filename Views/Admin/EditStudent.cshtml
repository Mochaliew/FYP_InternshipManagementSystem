@model AdminEditStudentViewModel
@{
    ViewData["Title"] = "Edit Student";
}

@await Html.PartialAsync("_AdminNav")

<style>
    .edit-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .edit-form-grid .full { grid-column: 1 / -1; }
    .form-action-row { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; }

    @@media (max-width: 800px) {
        .edit-form-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="admin-page-header">
    <div>
        <div class="admin-page-title">Edit Student</div>
        <div class="admin-page-sub">Update student details and account status</div>
    </div>
</div>

<div class="admin-table-card" style="max-width:900px">
    <form asp-action="EditStudent" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentId" />

        <div class="edit-form-grid">

            <div class="text-center mb-4">

                <img src="@(string.IsNullOrEmpty(Model.ProfilePicture)
                                 ? "/images/default-profile.png"
                                 : Model.ProfilePicture)"
                     style="
            width:140px;
            height:180px;
            object-fit:cover;
            border-radius:12px;
            border:3px solid #ddd;
            box-shadow:0 4px 12px rgba(0,0,0,.15);" />

                <br /><br />

                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <form asp-action="RemoveStudentProfilePicture"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="studentId"
                               value="@Model.StudentId" />

                        <button class="btn btn-outline-danger">
                            Remove Profile Picture
                        </button>

                    </form>
                }

            </div>

            <div class="form-group">
                <label>Name</label>
                <input asp-for="Name" class="form-input" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-input" readonly />
            </div>

            <div class="form-group">
                <label>Phone Number</label>
                <input asp-for="ContactNumber" class="form-input" />
            </div>

            <div class="form-group">
                <label>Programme</label>
                <input asp-for="Programme" class="form-input" />
            </div>

            <div class="form-group full">
                <label>Educational Institution</label>
                <input asp-for="EducationalInstitution" class="form-input" />
            </div>

            <div class="form-group">
                <label>CGPA</label>
                <input asp-for="CGPA" type="number" step="0.01" min="0" max="4" class="form-input" />
            </div>

            <div class="form-group">
                <label>Status</label>
                <select asp-for="Status" class="admin-select">
                    <option value="Active">Active</option>
                    <option value="Deactivated">Deactivated</option>
                </select>
            </div>
        </div>

        <div class="form-action-row">
            <a href="/Admin/ManageAccount" class="btn-muted">Cancel</a>
            <button type="submit" class="btn-dark">Save Changes</button>
        </div>
    </form>
</div>

@await Html.PartialAsync("_AdminNavClose")

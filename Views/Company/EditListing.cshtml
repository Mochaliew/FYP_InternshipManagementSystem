@model EditInternshipViewModel
@{
    ViewData["Title"] = "Student | Edit Listing Page";
}

@await Html.PartialAsync("_CompanyNav")

<div class="page-content">
    <div class="detail-card">
        <h4>Edit Listing Detail</h4>
        <form asp-action="EditListing" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InternshipId" />
            <input type="hidden" name="IsActive" value="@(Model.IsActive ? "true" : "false")" />

            <div class="form-group">
                <label>Title</label>
                <input asp-for="Title" class="form-input" />
            </div>
            <div class="form-group">
                <label>Department</label>
                <input asp-for="Department" class="form-input" />
            </div>
            <div class="form-group">
                <label>Duration</label>
                <input asp-for="Duration" class="form-input-sm" />
            </div>
            <div class="form-group">
                <label>Allowance</label>
                <input asp-for="Allowance" class="form-input-sm" placeholder="RM0000/month" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-textarea"></textarea>
            </div>
            <div class="profile-actions">
                <button type="submit" class="btn-dark">Save</button>
            </div>
        </form>

        <form asp-action="DeactivateListing" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.InternshipId" />
            <button type="submit" class="btn-danger" @(Model.IsActive ? "" : "disabled")>
                @(Model.IsActive ? "Deactivate Listing" : "Listing is Inactive")
            </button>
        </form>
    </div>
</div>

@model PostInternshipViewModel
@{
    ViewData["Title"] = "Post New Internship";
}

@await Html.PartialAsync("_CompanyNav")

<div class="page-content">
    <div class="detail-card">
        <h4>Post New Internship Listing</h4>
        <form asp-action="PostInternship" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="form-group">
                <label>Title</label>
                <input asp-for="Title" class="form-input" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="form-group">
                <label>Department</label>
                <input asp-for="Department" class="form-input" />
            </div>
            <div class="form-group">
                <label>Duration</label>
                <input asp-for="Duration" class="form-input-sm" placeholder="e.g. 3 months" />
            </div>
            <div class="form-group">
                <label>Allowance</label>
                <input asp-for="Allowance" class="form-input-sm" placeholder="RM0000/month" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-textarea"></textarea>
            </div>
            <div class="profile-actions">
                <a href="/Company/Listings" class="btn-muted">Cancel</a>
                <button type="submit" class="btn-dark">Post Listing</button>
            </div>
        </form>
    </div>
</div>

@model Application
@{
    ViewData["Title"] = "Student | Applicant Profile Page";
    var student = Model.Student;
}

@await Html.PartialAsync("_CompanyNav")

<div class="page-content">

    @* Approval success modal *@
    @if (ViewBag.ShowApprovedModal == true)
    {
        <div id="approvedModal" class="modal-overlay" style="display:flex">
            <div class="modal-box modal-box-approved">
                <div class="approved-icon">&#10003;</div>
                <h4>Application Approved!</h4>
                <p class="approved-msg">Please contact the applicant for any extra information (interview, meeting, etc.).</p>
                <div class="modal-actions" style="justify-content:center">
                    <button class="btn-dark" onclick="document.getElementById('approvedModal').style.display='none'">OK</button>
                </div>
            </div>
        </div>
    }

    @if (ViewBag.ShowRejectedBanner == true)
    {
        <div class="alert-error">Application has been rejected.</div>
    }

    <a href="/Company/ApplicationDetail/@Model.ApplicationId" class="back-link-page">&#8592; Back to Application Detail</a>

    <div class="profile-card">
        <div class="listing-title-row" style="margin-bottom:20px">
            <h4 style="margin:0">Applicant Profile</h4>
            @{
                string badgeClass = Model.Status switch
                {
                    "Approved" => "badge-approved",
                    "Rejected" => "badge-rejected",
                    _ => "badge-pending"
                };
            }
            <span class="@badgeClass">@Model.Status</span>
        </div>

        <div class="profile-pic-section">
            @if (!string.IsNullOrEmpty(student.ProfilePic))
            {
                <img src="@student.ProfilePic" class="profile-pic-img" alt="Profile" />
            }
            else
            {
                <div class="profile-pic-placeholder"><span>Photo</span></div>
            }
        </div>

        <div class="info-block">
            <div class="info-label-bold">Name</div>
            <div class="info-value">@student.User.Name</div>

            <div class="info-label-bold mt-1">Email Address</div>
            <div class="info-value">@student.User.Email</div>

            <div class="info-label-bold mt-1">Phone Number</div>
            <div class="info-value">@student.ContactNumber</div>

            <div class="info-label-bold mt-1">Educational Institution</div>
            <div class="info-value">@student.EducationalInstitution</div>

            <div class="info-label-bold mt-1">Programme</div>
            <div class="info-value">@student.Programme</div>

            <div class="info-label-bold mt-1">CGPA</div>
            <div class="info-value">@student.CGPA</div>

            @if (!string.IsNullOrEmpty(student.ResumeName))
            {
                <div class="info-label-bold mt-1">Resume</div>
                <div class="info-value"><a href="@student.ResumePath" target="_blank">@student.ResumeName</a></div>
            }
        </div>

        <div class="profile-actions">
            <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap">
                <button onclick="history.back()" class="btn-muted">Return</button>

                @if (Model.Status != "Rejected")
                {
                    <button type="button" class="btn-danger"
                            onclick="document.getElementById('rejectModal').style.display='flex'">
                        Reject
                    </button>
                }

                @if (Model.Status != "Approved")
                {
                    <form asp-action="UpdateApplicationStatus" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@Model.ApplicationId" />
                        <input type="hidden" name="status" value="Approved" />
                        <input type="hidden" name="returnTo" value="ApplicantProfile" />
                        <button type="submit" class="btn-success">Approve</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@* Reject Confirmation Modal *@
<div id="rejectModal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <h4>Reject Application</h4>
        <p class="modal-confirm-msg">Are you sure you want to reject <strong>@student.User.Name</strong>'s application for <strong>@Model.Internship.Title</strong>?</p>
        <div class="modal-actions">
            <button type="button" class="btn-muted"
                    onclick="document.getElementById('rejectModal').style.display='none'">Cancel</button>
            <form asp-action="UpdateApplicationStatus" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="applicationId" value="@Model.ApplicationId" />
                <input type="hidden" name="status" value="Rejected" />
                <input type="hidden" name="returnTo" value="ApplicantProfile" />
                <button type="submit" class="btn-danger">Confirm Reject</button>
            </form>
        </div>
    </div>
</div>

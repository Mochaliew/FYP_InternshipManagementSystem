@using FYP_InternshipManagementSystem.Models.ViewModels
@model FYP_InternshipManagementSystem.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Company Sign up";
}
<div class="auth-page company-auth-bg">
    <div class="auth-breadcrumb">Company Sign up</div>
    <div class="auth-outer">
        <a href="/" class="back-link">&#8592; Back to Home</a>
        <div class="auth-card">
            <h2>Company Account Register</h2>
            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" class="form-input" placeholder="Enter your Email ( XXX@gmail.my )" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-input" placeholder="Enter your Password" />
                </div>
                <div class="form-group">
                    <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Enter your Password again" />
                </div>
                <button type="submit" class="btn-dark btn-full">Register Account</button>
            </form>
            <div class="auth-footer">Have an Account ? <a href="/CompanyAuth/Login">Login Here</a></div>
        </div>
    </div>
</div>

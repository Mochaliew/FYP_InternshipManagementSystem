@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="home-page">
    <div class="home-container">
        <div class="home-welcome">
            <h2>Welcome to</h2>
            <h2>Internship Management System</h2>
        </div>
        <div class="role-cards">
            <a href="/StudentAuth/Login" class="role-card role-student">
                <span>Student</span>
            </a>
            <a href="/CompanyAuth/Login" class="role-card role-company">
                <span>Company</span>
            </a>
            <a href="/Admin/Login" class="role-card role-admin">
                <span>Administrator</span>
            </a>
        </div>
        <p class="home-hint">Select your role and log in/sign in to the system</p>
    </div>
</div>
